{
  "name": "crickmind",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared",
    "scripts"
  ],
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build": "cd client && npm run build && cd ../server && npm run build"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.2",
    "concurrently": "^9.1.0",
    "prisma": "^6.19.2",
    "typescript": "^5.7.0"
  }
}
